# Copy this to terraform.tfvars and adjust values
aws_region         = "us-east-1"
project_name       = "kafka-lab"
environment        = "dev"
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# Profile: 'sandbox' (default) or 'production'
# sandbox    → kafka.t3.small, 2 brokers, 10GB EBS, t3.small nodes, 1-2 nodes (~$5/day)
# production → kafka.m5.large, 3 brokers, 100GB EBS, t3.medium nodes, 2-4 nodes (~$13/day)
env_profile = "sandbox"

# Optional: override specific values from the profile
# msk_broker_instance = "kafka.t3.small"
# msk_broker_count    = 2

kafka_version = "3.9.x"
k8s_version   = "1.31"
